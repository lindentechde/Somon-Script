// Simple arithmetic test with Type Annotations

функсия тест_арифметика(): холӣ {
    тағ а: рақам = 10;
    тағ б: рақам = 3;
    
    чоп.сабт("а равно:");
    чоп.сабт(а);
    чоп.сабт("б равно:");
    чоп.сабт(б);
    
    тағ ҷамъ: рақам = а + б;
    чоп.сабт("ҷамъ равно:");
    чоп.сабт(ҷамъ);
    
    тағ тафрика: рақам = а - б;
    чоп.сабт("тафрика равно:");
    чоп.сабт(тафрика);
}

тест_арифметика();
